# ── Testnet RPC (default) ────────────────────────────────────────────────────
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Testnet contract addresses ────────────────────────────────────────────────
# These are the canonical testnet deployments (2026-03-26).
# Use the _TESTNET suffix variants when also configuring mainnet (see below).
VITE_QUEST_CONTRACT_ID=CC24Y3HPO4P4UPQ3CRORTCU6QV7YNZL4UNT4EKZUM2NIPPMH2OSTCPC6
VITE_MILESTONE_CONTRACT_ID=CAUQGMW72Z63QD6SVUBLUXJNWTUGCKINFZMFBR7I5WFX7QUI3RE6Q2B3
VITE_REWARDS_CONTRACT_ID=CBZN7TRWULHY6LQZH6YCSHDTPZRY6B6SQPW44JFO7EJCSWASH6ZW3TBD

# ── Per-network contract IDs (preferred when using the network switcher) ──────
# Testnet
# VITE_QUEST_CONTRACT_ID_TESTNET=CC24Y3HPO4P4UPQ3CRORTCU6QV7YNZL4UNT4EKZUM2NIPPMH2OSTCPC6
# VITE_MILESTONE_CONTRACT_ID_TESTNET=CAUQGMW72Z63QD6SVUBLUXJNWTUGCKINFZMFBR7I5WFX7QUI3RE6Q2B3
# VITE_REWARDS_CONTRACT_ID_TESTNET=CBZN7TRWULHY6LQZH6YCSHDTPZRY6B6SQPW44JFO7EJCSWASH6ZW3TBD

# Mainnet (fill in after deploying to mainnet)
# VITE_SOROBAN_RPC_URL_MAINNET=https://soroban-mainnet.stellar.org
# VITE_SOROBAN_NETWORK_PASSPHRASE_MAINNET=Public Global Stellar Network ; September 2015
# VITE_QUEST_CONTRACT_ID_MAINNET=C...
# VITE_MILESTONE_CONTRACT_ID_MAINNET=C...
# VITE_REWARDS_CONTRACT_ID_MAINNET=C...

# ── Misc ──────────────────────────────────────────────────────────────────────
# Analytics — set to "true" only for Vercel-hosted deployments.
# Leave unset or "false" for local dev and self-hosted builds.
VITE_ENABLE_ANALYTICS=false
